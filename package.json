  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.8.2",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.8.3",
    "wrangler": "^4.13.2"
  }
}
